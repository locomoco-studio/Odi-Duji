      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 노드 설정: \"Run Once for Each Item\" 모드일 때\nconst inputData = item.json || {};\nconst t = (inputData.parsed_markdown || '').toString();\n\n// doc_type이나 category가 없으면 'noise'로 기본값 설정\nlet d = inputData.doc_type || inputData.category || 'noise';\n\nif (/과제|LMS|제출/.test(t)) d = 'assignment';\nelse if (/영수증|결제|금액/.test(t)) d = 'receipt';\nelse if (/장학|성적증명서/.test(t)) d = 'scholarship';\nelse if (/지도|카카오맵|네이버지도|주소|위치/.test(t)) d = 'place';\nelse if (d !== 'assignment' && d !== 'receipt' && d !== 'scholarship' && d !== 'place') d = 'notice';\n\n// 항상 { json: { ... }, binary: ... } 구조 보장\nreturn {\n  json: {\n    ...inputData,\n    doc_type: d,\n    needs_review: !!inputData.needs_review\n  },\n  binary: item.binary\n};"
      },
