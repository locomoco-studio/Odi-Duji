        "jsCode": "// [주의] 이 노드의 모드가 \"Run Once for Each Item\"일 때 사용하는 코드입니다.\nconst jsonData = item.json || {};\nconst content = jsonData.content || {};\n\nconst parsed_markdown = content.markdown || content.html || '';\nconst layout_blocks = jsonData.elements || [];\n\n// 파싱 신뢰도 계산\nconst parse_confidence = (parsed_markdown.length > 100) ? 1.0\n  : (parsed_markdown.length > 20) ? 0.6 : 0.2;\n\n// item.json에 결과를 합쳐서 반환\nreturn {\n  json: {\n    ...jsonData,\n    parsed_markdown,\n    layout_blocks,\n    parse_confidence\n  },\n  binary: item.binary\n};"
