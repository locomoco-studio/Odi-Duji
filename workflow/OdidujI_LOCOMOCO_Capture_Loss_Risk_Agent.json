    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 노드 설정: \"Run Once for Each Item\"\nconst input = item.json || {};\n\n// capture_record라는 객체 내부에 필수 데이터를 안전하게 구성\nconst record = {\n  capture_id: input.capture_id || `CAP-${Date.now()}-${item.itemIndex}`,\n  doc_type: input.doc_type || 'noise',\n  deadline: input.deadline || null,\n  amount: input.amount || null,\n  evidence_text: input.evidence_text || null,\n  needs_review: !!input.needs_review,\n  // 원본 데이터 보존\n  source_image_path: input.source_image_path || null\n};\n\n// 항상 { json: {...}, binary: ... } 구조로 반환\nreturn {\n  json: {\n    ...input,\n    capture_record: record\n  },\n  binary: item.binary\n};"
      },
