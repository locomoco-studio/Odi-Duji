    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Build_Risk_Card 노드용 강력 방어 코드\nconst inputData = item.json || {};\nconst record = inputData.capture_record || {};\n\n// risk_card 객체를 명확하게 생성 (값이 없으면 null로 초기화)\nconst riskCard = {\n  capture_id: record.capture_id || `CAP-${Date.now()}`,\n  title: record.title || record.doc_type || \"Untitled\",\n  doc_type: record.doc_type || \"noise\",\n  deadline: record.deadline || null,\n  amount: record.amount || null,\n  required_submission: Array.isArray(record.required_submission) ? record.required_submission : [],\n  source_image_path: record.source_image_path || null,\n  evidence_text: record.evidence_text || null,\n  needs_review: !!record.needs_review\n};\n\n// n8n이 인식할 수 있는 표준 객체 반환\nreturn {\n  json: {\n    ...inputData,\n    risk_card: riskCard\n  },\n  binary: item.binary\n};"
      },
      "id": "90ba0dde-8187-409a-b44d-b595e96d80be",
