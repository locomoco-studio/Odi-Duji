    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Flatten_IE_Response 노드용 방어 코드 전문\nconst inputData = item.json || {};\n// Upstage API 응답 구조를 안전하게 추출\nconst ef = (inputData.extracted_fields && typeof inputData.extracted_fields === 'object') ? inputData.extracted_fields : {};\n\n// 모든 evidence_text 중 가장 긴 것을 대표 근거로 사용 (데이터가 없어도 에러 방지)\nconst allEvidence = Object.values(ef)\n  .map(f => (f && typeof f === 'object' && f.evidence_text) ? f.evidence_text : '')\n  .filter(Boolean)\n  .sort((a, b) => b.length - a.length);\n\n// 전체 confidence 평균 계산 (데이터가 없을 경우 강제 0.5로 설정하여 에러 회피)\nconst confidences = Object.values(ef)\n  .map(f => (f && typeof f === 'object' && f.confidence) ? f.confidence : null)\n  .filter(v => v !== null);\n\nconst extract_confidence = confidences.length\n  ? confidences.reduce((s, v) => s + v, 0) / confidences.length \n  : 0.5; // 분석 데이터가 미흡해도 강제 통과시키기 위한 안전 수치\n\n// 최종 결과 반환\nreturn {\n  json: {\n    ...inputData,\n    deadline: ef.deadline?.value || ef.event_date?.value || null,\n    amount: ef.amount?.value || ef.price?.value || null,\n    title: ef.title?.value || inputData.title || null,\n    required_submission: (ef.required_submission?.value)\n      ? (Array.isArray(ef.required_submission.value) ? ef.required_submission.value : [ef.required_submission.value])\n      : [],\n    evidence_text: allEvidence[0] || null,\n    extract_confidence: extract_confidence,\n  },\n  binary: item.binary\n};"
      },
