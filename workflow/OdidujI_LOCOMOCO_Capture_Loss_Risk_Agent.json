    {
      "parameters": {
        "jsCode": "const queryPlan = $json.query_plan || $json;\nconst intent = queryPlan.query_intent || '';\nconst filters = queryPlan.filters || {};\nconst sortBy = queryPlan.sort_by || 'deadline';\nconst limit = queryPlan.limit || 5;\n\n// 전체 인덱스 레코드 수집\nconst allRecords = items\n  .map(i => i.json.capture_record || i.json)\n  .filter(r => r.evidence_text && r.doc_type !== 'noise');\n\n// 필터링\nconst filtered = allRecords.filter(r => {\n  // doc_type 필터\n  if (filters.doc_type && r.doc_type !== filters.doc_type) return false;\n\n  // date_range 필터\n  if (filters.date_range?.start || filters.date_range?.end) {\n    const deadline = r.deadline ? new Date(r.deadline) : null;\n    if (!deadline) return false;\n    if (filters.date_range.start && deadline < new Date(filters.date_range.start)) return false;\n    if (filters.date_range.end   && deadline > new Date(filters.date_range.end))   return false;\n  }\n\n  // keywords 필터\n  if (filters.keywords?.length) {\n    const text = [r.evidence_text, r.title, r.doc_type].join(' ').toLowerCase();\n    return filters.keywords.some(k => text.includes(k.toLowerCase()));\n  }\n\n  return true;\n});\n\n// 정렬\nfiltered.sort((a, b) => {\n  if (sortBy === 'deadline') {\n    return (a.deadline || '9999') < (b.deadline || '9999') ? -1 : 1;\n  }\n  if (sortBy === 'amount') {\n    return (Number(b.amount) || 0) - (Number(a.amount) || 0);\n  }\n  return (b.uploaded_at || '') > (a.uploaded_at || '') ? -1 : 1;  // fix #10: 최신 먼저\n});\n\nconst candidates = filtered.slice(0, limit);\n\nreturn [{ json: { ...$json, candidate_results: candidates } }];"
      },
